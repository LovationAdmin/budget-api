# ============================================================================
# BUDGET FAMILLE API - Configuration
# ============================================================================
# Copier ce fichier en `.env` et remplir avec les vraies valeurs.
# NE JAMAIS commiter le `.env` réel dans Git.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# Format : postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=...
DATABASE_URL=postgres://user:password@localhost:5432/budget_db?sslmode=disable

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
# Générer une clé secrète forte : `openssl rand -base64 48`
JWT_SECRET=__REPLACE_WITH_RANDOM_BASE64_SECRET__
JWT_EXPIRY=15m
REFRESH_EXPIRY=168h

# ----------------------------------------------------------------------------
# CHIFFREMENT DES DONNÉES (AES-256-GCM)
# ----------------------------------------------------------------------------
# DOIT être exactement 32 caractères (32 octets ASCII).
# Générer : `openssl rand -hex 16` (donne 32 caractères hex)
# ATTENTION : la perte de cette clé rend toutes les données budgétaires
# définitivement illisibles. Sauvegarder en lieu sûr.
DATA_ENCRYPTION_KEY=__REPLACE_WITH_EXACTLY_32_CHARACTERS__

# ----------------------------------------------------------------------------
# FRONTEND (CORS et liens email)
# ----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# EMAIL (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=Budget Famille <noreply@example.com>
CAMPAIGN_FROM_EMAIL=Libasse — Budget Famille <libasse@budgetfamille.com>
CAMPAIGN_REPLY_TO=lovation.pro@gmail.com

# ----------------------------------------------------------------------------
# SERVEUR
# ----------------------------------------------------------------------------
PORT=8080
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# BRIDGE API (legacy banking)
# ----------------------------------------------------------------------------
BRIDGE_CLIENT_ID=your_bridge_client_id
BRIDGE_CLIENT_SECRET=your_bridge_client_secret
BRIDGE_ENV=sandbox

# ----------------------------------------------------------------------------
# CLAUDE / ANTHROPIC API
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ----------------------------------------------------------------------------
# ADMIN
# ----------------------------------------------------------------------------
# Secret pour les routes /admin/migrate-* (header X-Admin-Secret)
ADMIN_SECRET=__REPLACE_WITH_RANDOM_SECRET__

# ----------------------------------------------------------------------------
# ENABLE BANKING (PSD2 - 2500+ banques européennes)
# ----------------------------------------------------------------------------
ENABLE_BANKING_APP_ID=your_app_uuid_here
# Soit le path vers le PEM, soit le PEM en base64 (un seul des deux)
ENABLE_BANKING_PRIVATE_KEY_PATH=./private-key.pem
ENABLE_BANKING_PRIVATE_KEY_BASE64=

# ----------------------------------------------------------------------------
# CACHE
# ----------------------------------------------------------------------------
CACHE_DURATION_DAYS=30
DEFAULT_USER_COUNTRY=FR

# ----------------------------------------------------------------------------
# OBSERVABILITY (Sentry)
# ----------------------------------------------------------------------------
# Vide = Sentry désactivé. Récupérer le DSN sur https://sentry.io/
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Sampling rate des traces de performance, 0.0 à 1.0 (0 par défaut)
SENTRY_TRACES_RATE=0.0